IDELIUM_VERSION=local
APP_ENV=production
APP_URL=https://localhost
CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:5173,http://127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
HTTPS_PORT=443
DB_DATABASE=ideliumdb
DB_USERNAME=idelium
DB_PASSWORD_FILE=./secrets/db_password
DB_ROOT_PASSWORD_FILE=./secrets/db_root_password
APP_KEY_FILE=./secrets/app_key
DEMO_EMAIL_FILE=./secrets/demo_email
DEMO_PASSWORD_FILE=./secrets/demo_password
ADMIN_EMAIL_FILE=./secrets/admin_email
ADMIN_PASSWORD_FILE=./secrets/admin_password
TLS_MODE=production
TLS_COMMON_NAME=localhost
TLS_CERT_DIR=./certs
API_SOURCE_REVISION=unknown
WEB_SOURCE_REVISION=unknown
STACK_SOURCE_REVISION=unknown
API_IMAGE=idelium/api
WEB_IMAGE=idelium/web
DB_IMAGE=idelium/db
